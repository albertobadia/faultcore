FROM rust:latest

RUN apt-get update && apt-get install -y \
    build-essential \
    curl \
    python3 \
    python3-venv \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /root/.local/bin/
ENV PATH="/root/.local/bin:$PATH"

WORKDIR /workspace

# Copy all project files
COPY . .

# Build Rust interceptor
RUN cd faultcore_interceptor && cargo build --release

# Setup Python environment with maturin
RUN uv venv .venv && \
    . .venv/bin/activate && \
    uv pip install maturin pytest requests

# Build faultcore Python module (MUST be after COPY . . to use copied sources)
RUN . .venv/bin/activate && maturin develop

ENV PATH="/workspace/.venv/bin:$PATH"
ENV PYTHONPATH=/workspace

CMD ["/bin/bash"]
